# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA versione o arquivo .env.

# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Caminhos de dados (use pathlib.Path no settings.py; este valor é opcional)
# Se não definido, o código usa BASE_DIR / "data" como padrão.
DATA_DIR=

# Banco de dados (deixe em branco para usar SQLite em desenvolvimento)
DATABASE_URL=

# E-mail (para notificações de pipeline, fase futura)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
